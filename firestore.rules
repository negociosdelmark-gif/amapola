rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the document belongs to the logged-in user
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User profiles match (per-user document and all subcollections)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // Child profiles match (document has a userId field or matches auth)
    match /profiles/{profileId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // Assessments / consultations history match (document has a userId field or matches auth)
    match /assessments/{assessmentId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
  }
}
